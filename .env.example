# Salin ke `.env` di folder yang sama dengan docker-compose.yml, lalu ubah jika port masih bentrok.
# Docker Compose memuat `.env` otomatis untuk substitusi ${VAR:-default} di docker-compose.yml.

LHMETA_MINIO_API_PORT=19000
LHMETA_MINIO_CONSOLE_PORT=19001
LHMETA_POSTGRES_PORT=15432
LHMETA_SOLR_PORT=18984
LHMETA_HBASE_MASTER_PORT=19010
LHMETA_HIVE_METASTORE_PORT=19083
LHMETA_ATLAS_PORT=22100
LHMETA_SPARK_MASTER_UI_PORT=18080
LHMETA_SPARK_MASTER_PORT=17077
LHMETA_AIRFLOW_WEB_PORT=18681
LHMETA_CATALOG_PORT=13000
LHINSIGHT_PORTAL_PORT=13000

# URL untuk embed di portal (browser host — bukan hostname Docker internal)
LHINSIGHT_PORTAL_PRODUCTION=0
LHINSIGHT_GRAFANA_PUBLIC_URL=http://localhost:13001
LHINSIGHT_SUPERSET_PUBLIC_URL=http://localhost:18089
LHINSIGHT_PROMETHEUS_PUBLIC_URL=http://localhost:19090
LHINSIGHT_GRAFANA_PORT=13001
LHINSIGHT_SUPERSET_PORT=18089
