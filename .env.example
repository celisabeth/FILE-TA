# Salin ke `.env` di folder yang sama dengan docker-compose.yml, lalu ubah jika port masih bentrok.
# Docker Compose memuat `.env` otomatis untuk substitusi ${VAR:-default} di docker-compose.yml.

LHMETA_MINIO_API_PORT=19000
LHMETA_MINIO_CONSOLE_PORT=19001
LHMETA_POSTGRES_PORT=15432
LHMETA_SOLR_PORT=18984
LHMETA_HBASE_MASTER_PORT=19010
LHMETA_HIVE_METASTORE_PORT=19083
LHMETA_ATLAS_PORT=22100
LHMETA_SPARK_MASTER_UI_PORT=18080
LHMETA_SPARK_MASTER_PORT=17077
LHMETA_AIRFLOW_WEB_PORT=18681
LHMETA_CATALOG_PORT=13000
LHINSIGHT_PORTAL_PORT=13000

# ── Host publik VM (browser user) ─────────────────────────────────────────────
# Ganti dengan IP/domain server Anda (contoh: 103.179.57.24)
LHINSIGHT_PUBLIC_HOST=103.179.57.24

# ── URL layanan untuk embed portal (browser — bukan hostname Docker) ─────────
LHINSIGHT_PORTAL_PRODUCTION=0
LHINSIGHT_GRAFANA_PUBLIC_URL=http://103.179.57.24:13001
LHINSIGHT_SUPERSET_PUBLIC_URL=http://103.179.57.24:18089
LHINSIGHT_PROMETHEUS_PUBLIC_URL=http://103.179.57.24:19090
LHINSIGHT_GRAFANA_PORT=13001
LHINSIGHT_SUPERSET_PORT=18089

# ── Grafana — URL dashboard lengkap (dari Share link di Grafana UI) ─────────
# Portal memakai ini untuk iframe; &kiosk ditambahkan otomatis pada embed URL.
# EXTERNAL = tab baru (tanpa kiosk); kosongkan → sama dengan embed tanpa kiosk.

LHINSIGHT_GRAFANA_EMBED_INSIGHT_URL=http://103.179.57.24:13001/d/lakehouse-dashboard-insight/aef4ac2b-4c1c-5387-b166-4b1ebf37117a?orgId=1&refresh=30s&theme=light
LHINSIGHT_GRAFANA_EMBED_INSIGHT_EXTERNAL_URL=http://103.179.57.24:13001/d/lakehouse-dashboard-insight/aef4ac2b-4c1c-5387-b166-4b1ebf37117a?orgId=1&refresh=30s&theme=light

LHINSIGHT_GRAFANA_EMBED_AQE_URL=http://103.179.57.24:13001/d/lakehouse-aqe-experiment/lakehouse-aqe-experiment?orgId=1&refresh=30s&theme=light
LHINSIGHT_GRAFANA_EMBED_AQE_EXTERNAL_URL=http://103.179.57.24:13001/d/lakehouse-aqe-experiment/lakehouse-aqe-experiment?orgId=1&refresh=30s&theme=light

LHINSIGHT_GRAFANA_EMBED_MLOPS_URL=http://103.179.57.24:13001/d/lakehouse-mlops-pipeline/mlops-pipeline-monitoring?orgId=1&refresh=30s&theme=light
LHINSIGHT_GRAFANA_EMBED_MLOPS_EXTERNAL_URL=http://103.179.57.24:13001/d/lakehouse-mlops-pipeline/mlops-pipeline-monitoring?orgId=1&refresh=30s&theme=light

# Opsional: Superset embed path setelah dashboard dibuat
# LHINSIGHT_SUPERSET_EMBED_PATH=/superset/dashboard/1/?standalone=1

# Grafana admin (login iframe / tab baru)
# LHINSIGHT_GRAFANA_PASSWORD=admin
