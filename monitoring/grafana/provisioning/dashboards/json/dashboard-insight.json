{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "MLOps Pipeline & metrik model",
      "type": "link",
      "url": "/d/lakehouse-mlops-pipeline",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Output inference (snapshot) — analitik detail di Superset · metrik latih di MLOps Pipeline",
      "type": "row",
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Capaian IKU institusi per tahun. Model: ETS / Holt-Winters (statsmodels) atau Ridge. Metrik latih: MAE, RMSE, MAPE — lihat dashboard MLOps Pipeline.",
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 1 },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/forecast/i" },
            "properties": [{ "id": "custom.fillOpacity", "value": 40 }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 2 },
      "id": 10,
      "title": "Forecast — Actual vs Prediksi (IKU)",
      "type": "barchart",
      "options": {
        "orientation": "vertical",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "barWidth": 0.8,
        "groupWidth": 0.7
      },
      "targets": [
        {
          "expr": "lakehouse_insight_forecast{series=\"actual\"}",
          "instant": true,
          "legendFormat": "Actual {{tahun}}"
        },
        {
          "expr": "lakehouse_insight_forecast{series=\"forecast\"}",
          "instant": true,
          "legendFormat": "Forecast {{tahun}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Skor risiko capaian IKU per prodi (0–100). Model: Random Forest / GBT (sklearn / Spark MLlib). Threshold bisnis: merah <60, hijau ≥80.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 2 },
      "id": 11,
      "title": "Risk Score — per Prodi",
      "type": "bargauge",
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "lakehouse_insight_risk_score",
          "instant": true,
          "legendFormat": "{{prodi_id}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Indeks peluang peningkatan per prodi. Model: K-Means (Spark MLlib / sklearn). Label cluster: high_research, mbkm_growth, …",
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "id": 12,
      "title": "Opportunity — Skor per Prodi (cluster)",
      "type": "barchart",
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" },
        "showValue": "always"
      },
      "targets": [
        {
          "expr": "lakehouse_insight_opportunity_score",
          "instant": true,
          "legendFormat": "{{prodi_id}} ({{cluster}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Jumlah entitas ter-flag anomali. Model: Isolation Forest (sklearn / PyOD).",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 11 },
      "id": 13,
      "title": "Anomalies — Count",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "lakehouse_insight_anomaly_count",
          "instant": true,
          "legendFormat": "anomalies"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Persentase record anomali pada set evaluasi.",
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 11 },
      "id": 14,
      "title": "Anomalies — Rate (%)",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "lakehouse_insight_anomaly_rate_percent",
          "instant": true,
          "legendFormat": "rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Sampel nilai capaian IKU yang ter-flag anomali (bukan time series).",
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 }, "overrides": [] },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 15 },
      "id": 15,
      "title": "Anomalies — Nilai ter-flag",
      "type": "barchart",
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" },
        "showValue": "always"
      },
      "targets": [
        {
          "expr": "lakehouse_insight_anomaly_flag",
          "instant": true,
          "legendFormat": "{{entity}} {{tahun}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["lakehouse", "insight", "mlops", "forecast", "risk", "opportunity", "anomaly"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
