{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Dashboard Insight",
      "type": "link",
      "url": "/d/lakehouse-dashboard-insight",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Durasi task DAG mlops_pipeline (snapshot terakhir dari metrics-exporter).",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 20,
      "title": "MLOps Pipeline — Task Duration",
      "type": "bargauge",
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "lakehouse_mlops_task_duration_seconds",
          "instant": true,
          "legendFormat": "{{task}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Metrik numerik training (accuracy, MAE, dll.). Kosong jika DAG belum train atau hanya model placeholder — jalankan mlops_pipeline task train_models.",
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 21,
      "title": "Model Training Metrics",
      "type": "barchart",
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" },
        "showValue": "always"
      },
      "targets": [
        {
          "expr": "lakehouse_mlops_model_metric",
          "instant": true,
          "legendFormat": "{{model}} — {{metric}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 8 },
      "id": 22,
      "title": "Output use cases (ringkasan)",
      "type": "row",
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 11 },
      "id": 23,
      "title": "Forecast points",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "count(lakehouse_insight_forecast)",
          "instant": true,
          "legendFormat": "points"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 11 },
      "id": 24,
      "title": "Risk Score (prodi)",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "count(lakehouse_insight_risk_score)",
          "instant": true,
          "legendFormat": "prodi"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 11 },
      "id": 25,
      "title": "Opportunity (prodi)",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "count(lakehouse_insight_opportunity_score)",
          "instant": true,
          "legendFormat": "prodi"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 11 },
      "id": 26,
      "title": "Anomalies flagged",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "lakehouse_insight_anomaly_count",
          "instant": true,
          "legendFormat": "count"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["lakehouse", "mlops", "pipeline", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
